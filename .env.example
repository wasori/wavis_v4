# =========================================================
# WAVIS v4 environment example
# 이 파일은 예시 파일이다.
# 실제 실행 시에는 이 파일을 복사해서 ".env" 파일로 만들고 값을 채운다.
# =========================================================

# -------------------------
# 기본 실행 모드
# -------------------------
# test  : 조회/테스트 중심
# live  : 실제 주문 가능 모드
APP_MODE=test

# -------------------------
# 장치 식별
# -------------------------
# 집 PC와 노트북을 구분하기 위한 값
# 예:
# DEVICE_ID=home-pc
# DEVICE_ID=laptop
DEVICE_ID=your-device-name

# -------------------------
# 업비트 API 키
# -------------------------
UPBIT_ACCESS_KEY=your-upbit-access-key
UPBIT_SECRET_KEY=your-upbit-secret-key

# -------------------------
# 서버 기본 설정
# -------------------------
HOST=0.0.0.0
PORT=8787

# -------------------------
# 로그 / 상태 저장 경로
# 상대경로 기준: 프로젝트 루트 기준으로 사용 예정
# -------------------------
LOG_DIR=logs
STATE_DIR=state

# -------------------------
# 엔진 잠금 파일
# 동시에 여러 장치에서 실거래 중복 실행되는 것을 막기 위한 파일
# -------------------------
ENGINE_LOCK_FILE=state/engine_lock.json

# -------------------------
# BTC 보유 포트 비율
# 예: 0.60 = 전체 자산의 60%
# -------------------------
BTC_PORTFOLIO_RATIO=0.60

# -------------------------
# 단타 포트 비율
# 예: 0.40 = 전체 자산의 40%
# -------------------------
TRADE_PORTFOLIO_RATIO=0.40

# -------------------------
# 단타 기본 대상 종목
# 처음에는 1~2개만 운영 권장
# 쉼표(,)로 구분
# -------------------------
TRADE_SYMBOLS=KRW-BTC,KRW-ETH

# -------------------------
# 단타 1회 진입 비율
# 예: 0.10 = 단타 포트의 10%
# -------------------------
TRADE_ENTRY_RATIO=0.10

# -------------------------
# 단타 손절 / 익절 기준
# 예: 0.008 = 0.8%
# -------------------------
STOP_LOSS_PCT=0.008
TAKE_PROFIT_PCT=0.010

# -------------------------
# 일일 손실 제한
# 예: 0.02 = 2%
# -------------------------
DAILY_LOSS_LIMIT_PCT=0.02

# -------------------------
# 연속 손실 제한
# -------------------------
MAX_CONSECUTIVE_LOSSES=2

# -------------------------
# 업비트 최소 주문 금액
# -------------------------
MIN_ORDER_KRW=5000

# -------------------------
# BTC 급락 매수 기준
# 최근 기준 고점 대비 하락률
# 예: 0.10 = -10%
# -------------------------
BTC_DROP_BUY_1=0.10
BTC_DROP_BUY_2=0.15
BTC_DROP_BUY_3=0.20

# -------------------------
# BTC 급락 단계별 사용 비율
# BTC 포트 현금 기준
# -------------------------
BTC_BUY_RATIO_1=0.20
BTC_BUY_RATIO_2=0.30
BTC_BUY_RATIO_3=0.50